; nixconf editorconfig

root = true

[*]
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[{go.mod,go.sum,.gitmodules}]
indent_style = tab
indent_size = 4

[*.go]
indent_style = unset
indent_size = unset

[*.md]
trim_trailing_whitespace = false

eclint_indent_style = unset

[LICENSE]
charset = unset
end_of_line = unset
insert_final_newline = unset
trim_trailing_whitespace = unset
indent_style = unset
indent_size = unset
